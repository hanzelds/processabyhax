generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEAD
  TEAM
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  POTENTIAL
}

enum ClientTier {
  STRATEGIC
  REGULAR
  PUNCTUAL
  POTENTIAL
}

enum ClientHistoryEventType {
  client_created
  status_changed
  tier_changed
  contact_added
  contact_removed
  contact_set_primary
  tag_added
  tag_removed
  project_created
  project_completed
}

enum ProjectStatus {
  ACTIVE
  IN_PROGRESS
  COMPLETED
}

enum TaskType {
  DISENO
  EDICION_VIDEO
  ESTRATEGIA
  PROPUESTA
  PRODUCCION
  POST_PRODUCCION
  PRE_PRODUCCION
  COPY
  FOTOGRAFIA
  CONTENIDO_REDES
  OTRO
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  BLOCKED
}

enum RoleInProject {
  lead
  executor
}

enum ProjectFileType {
  brief
  reference
  contract
  other
}

enum ProjectHistoryEventType {
  project_created
  status_changed
  end_date_changed
  member_added
  member_removed
  task_created
  task_status_changed
  file_uploaded
  file_deleted
}

enum ActivityEventType {
  task_created
  task_status_changed
  task_assigned
  project_created
  project_status_changed
  client_created
  client_status_changed
}

enum ActivityEntityType {
  task
  project
  client
}

model User {
  id          String     @id @default(cuid())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(TEAM)
  status      UserStatus @default(ACTIVE)
  area        String?
  avatarUrl   String?
  bio         String?
  phone            String?
  whatsappNotif    Boolean   @default(true)
  joinedAt    DateTime?
  lastSeenAt  DateTime?
  createdAt   DateTime   @default(now())

  taskAssignments     TaskAssignee[]
  activityLogs        ActivityLog[]
  projectMemberships  ProjectMember[]          @relation("ProjectMemberUser")
  projectMemberAdds   ProjectMember[]          @relation("ProjectMemberAddedBy")
  teamspaceMemberships TeamspaceMember[]
  projectFiles        ProjectFile[]
  projectHistories    ProjectHistory[]
  clientNotes         ClientNote[]
  clientHistories     ClientHistory[]
  skills              UserSkill[]
  invitation          UserInvitation?
  refreshTokens       RefreshToken[]
  passwordResets      PasswordReset[]
  permissionOverrides UserPermissionOverride[] @relation("UserOverrides")
  grantedOverrides    UserPermissionOverride[] @relation("GrantedBy")
  adminTasks          AdminTask[]              @relation("AdminTaskCreatedBy")
  adminRecurrences    AdminTaskRecurrence[]    @relation("AdminRecurrenceCreatedBy")
  adminTaskHistory    AdminTaskHistory[]       @relation("AdminTaskHistoryActor")
  // Content modules
  monthlyObjectives   ClientMonthlyObjective[]
  briefsCreated       ContentBrief[]           @relation("BriefCreatedBy")
  briefAssignments    BriefAssignee[]          @relation("BriefAssigneeUser")
  briefsAssigned      BriefAssignee[]          @relation("BriefAssignedBy")
  briefHistory        BriefHistory[]           @relation("BriefHistoryActor")
  briefFiles          BriefFile[]              @relation("BriefFileUploader")
  contentPieces       ContentPiece[]           @relation("PieceCreatedBy")
  pieceHistory        ContentPieceHistory[]    @relation("PieceHistoryActor")
  // Docs
  docPagesCreated     DocPage[]                @relation("DocPageCreator")
  docPagesUpdated     DocPage[]                @relation("DocPageUpdater")
  docPagesApproved    DocPage[]                @relation("DocPageApprover")
  docVersions         DocPageVersion[]         @relation("DocVersionSaver")
  docFavorites        DocFavorite[]            @relation("DocFavoriteUser")
  // Brief comments
  briefComments       BriefComment[]           @relation("BriefCommentAuthor")
  resolvedComments    BriefComment[]           @relation("BriefCommentResolver")
  commentMentions     CommentMention[]         @relation("CommentMentionUser")
  driveConnections    DriveConnection[]
  // Scripts
  scriptsCreated      Script[]             @relation("ScriptCreator")
  scriptsUpdated      Script[]             @relation("ScriptUpdater")
  scriptVersions      ScriptVersion[]      @relation("ScriptVersionSaver")
  scriptComments      ScriptComment[]      @relation("ScriptCommentAuthor")
  scriptMentions      ScriptCommentMention[] @relation("ScriptMentionUser")

  @@map("users")
}

model Skill {
  id    String      @id @default(cuid())
  name  String      @unique
  users UserSkill[]

  @@map("skills")
}

model UserSkill {
  userId  String
  skillId String
  user    User   @relation(fields: [userId], references: [id])
  skill   Skill  @relation(fields: [skillId], references: [id])

  @@id([userId, skillId])
  @@map("user_skills")
}

model UserInvitation {
  id         String    @id @default(cuid())
  userId     String    @unique
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])

  @@map("user_invitations")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@map("password_resets")
}

model UserPermissionOverride {
  id          String   @id @default(cuid())
  userId      String
  permission  String
  granted     Boolean
  grantedById String
  createdAt   DateTime @default(now())
  user        User     @relation("UserOverrides", fields: [userId], references: [id])
  grantedBy   User     @relation("GrantedBy", fields: [grantedById], references: [id])

  @@unique([userId, permission])
  @@index([userId])
  @@map("user_permission_overrides")
}

model Client {
  id            String       @id @default(cuid())
  name          String
  contactName   String
  contactInfo   String
  status        ClientStatus @default(ACTIVE)
  industry      String?
  tier          ClientTier   @default(REGULAR)
  website       String?
  description   String?
  relationStart DateTime?
  color         String?
  createdAt     DateTime     @default(now())
  projects      Project[]
  contacts      ClientContact[]
  tags          ClientTag[]
  notes         ClientNote[]
  history       ClientHistory[]
  briefs        ContentBrief[]
  contentPieces ContentPiece[]
  portalTokens  ClientPortalToken[]
  monthlyObjectives ClientMonthlyObjective[]
  contentApprovals  ClientContentApproval[]
  scripts       Script[]          @relation("ClientScripts")

  @@map("clients")
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())

  @@index([clientId, isPrimary])
  @@map("client_contacts")
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  clients ClientTag[]

  @@map("tags")
}

model ClientTag {
  clientId String
  tagId    String
  client   Client @relation(fields: [clientId], references: [id])
  tag      Tag    @relation(fields: [tagId], references: [id])

  @@id([clientId, tagId])
  @@index([clientId])
  @@map("client_tags")
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, isPinned, createdAt(sort: Desc)])
  @@map("client_notes")
}

model ClientHistory {
  id          String                 @id @default(cuid())
  clientId    String
  client      Client                 @relation(fields: [clientId], references: [id])
  actorId     String
  actor       User                   @relation(fields: [actorId], references: [id])
  eventType   ClientHistoryEventType
  description String
  meta        Json?
  createdAt   DateTime               @default(now())

  @@index([clientId, createdAt(sort: Desc)])
  @@map("client_history")
}

model Project {
  id             String        @id @default(cuid())
  name           String
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  teamspaceId    String?
  teamspace      Teamspace?    @relation(fields: [teamspaceId], references: [id])
  description    String?
  status         ProjectStatus @default(ACTIVE)
  startDate      DateTime
  estimatedClose DateTime?
  closedAt       DateTime?
  createdAt      DateTime      @default(now())
  tasks          Task[]
  briefs         ContentBrief[]  @relation("BriefProject")
  members        ProjectMember[]
  files          ProjectFile[]
  history        ProjectHistory[]

  @@map("projects")
}

model Task {
  id          String         @id @default(cuid())
  title       String
  description String?
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id])
  briefId     String?        @map("brief_id")
  brief       ContentBrief?  @relation("BriefTasks", fields: [briefId], references: [id], onDelete: SetNull)
  assignees   TaskAssignee[]
  status      TaskStatus     @default(PENDING)
  taskType    TaskType?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("tasks")
}

model TaskAssignee {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())
  assignedBy String?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@id([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model ProjectMember {
  id            String        @id @default(cuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id])
  userId        String
  user          User          @relation("ProjectMemberUser", fields: [userId], references: [id])
  roleInProject RoleInProject @default(executor)
  addedAt       DateTime      @default(now())
  addedById     String
  addedBy       User          @relation("ProjectMemberAddedBy", fields: [addedById], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model ProjectFile {
  id           String          @id @default(cuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id])
  uploadedById String
  uploader     User            @relation(fields: [uploadedById], references: [id])
  originalName String
  storedName   String
  filePath     String
  fileType     ProjectFileType @default(other)
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime        @default(now())

  @@index([projectId])
  @@map("project_files")
}

model ProjectHistory {
  id          String                  @id @default(cuid())
  projectId   String
  project     Project                 @relation(fields: [projectId], references: [id])
  actorId     String
  actor       User                    @relation(fields: [actorId], references: [id])
  eventType   ProjectHistoryEventType
  description String
  meta        Json?
  createdAt   DateTime                @default(now())

  @@index([projectId, createdAt(sort: Desc)])
  @@map("project_history")
}

// ── Admin Tasks ──────────────────────────────────────────────────────────────

enum AdminTaskCategory {
  EQUIPO
  FINANZAS
  LEGAL_CONTRATOS
  INFRAESTRUCTURA
  ESTRATEGIA
  OPERACIONES
  OTRO
}

enum AdminTaskPriority {
  URGENTE
  ALTA
  NORMAL
  BAJA
}

enum AdminTaskStatus {
  PENDIENTE
  EN_PROGRESO
  BLOQUEADA
  COMPLETADA
  CANCELADA
}

enum RecurrenceFrequency {
  DIARIO
  SEMANAL
  MENSUAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

model AdminTaskRecurrence {
  id               String              @id @default(cuid())
  title            String
  description      String?
  category         AdminTaskCategory
  priority         AdminTaskPriority   @default(NORMAL)
  frequency        RecurrenceFrequency
  dayOfMonth       Int?
  monthOfYear      Int?
  dayOfWeek        Int?
  advanceDays      Int                 @default(0)
  isActive         Boolean             @default(true)
  lastGeneratedAt  DateTime?
  nextGenerationAt DateTime?
  createdById      String
  createdAt        DateTime            @default(now())
  createdBy        User                @relation("AdminRecurrenceCreatedBy", fields: [createdById], references: [id])
  tasks            AdminTask[]

  @@index([nextGenerationAt, isActive])
  @@map("admin_task_recurrences")
}

model AdminTask {
  id              String             @id @default(cuid())
  title           String
  description     String?
  category        AdminTaskCategory
  priority        AdminTaskPriority  @default(NORMAL)
  status          AdminTaskStatus    @default(PENDIENTE)
  dueDate         DateTime?
  resolutionNotes String?
  recurrenceId    String?
  recurrence      AdminTaskRecurrence? @relation(fields: [recurrenceId], references: [id])
  createdById     String
  createdBy       User               @relation("AdminTaskCreatedBy", fields: [createdById], references: [id])
  completedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  history         AdminTaskHistory[]

  @@index([status, priority])
  @@index([dueDate, status])
  @@index([category, status])
  @@map("admin_tasks")
}

model AdminTaskHistory {
  id          String    @id @default(cuid())
  taskId      String
  task        AdminTask @relation(fields: [taskId], references: [id])
  actorId     String
  actor       User      @relation("AdminTaskHistoryActor", fields: [actorId], references: [id])
  eventType   String
  description String
  meta        Json?
  createdAt   DateTime  @default(now())

  @@index([taskId, createdAt(sort: Desc)])
  @@map("admin_task_history")
}

// ── Teamspaces ───────────────────────────────────────────────────────────────

enum TeamspaceVisibility {
  OPEN
  CLOSED
  PRIVATE
}

model Teamspace {
  id          String              @id @default(cuid())
  name        String
  emoji       String              @default("🏢")
  description String?
  visibility  TeamspaceVisibility @default(OPEN)
  createdAt   DateTime            @default(now())
  members     TeamspaceMember[]
  projects    Project[]

  @@map("teamspaces")
}

model TeamspaceMember {
  teamspaceId String
  userId      String
  joinedAt    DateTime  @default(now())
  teamspace   Teamspace @relation(fields: [teamspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamspaceId, userId])
  @@index([userId])
  @@map("teamspace_members")
}

model ActivityLog {
  id         String              @id @default(cuid())
  actorId    String
  actor      User                @relation(fields: [actorId], references: [id])
  eventType  ActivityEventType
  entityType ActivityEntityType
  entityId   String
  entityName String
  meta       Json?
  createdAt  DateTime            @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("activity_log")
}

// ── Content Modules ──────────────────────────────────────────────────────────

enum ContentType {
  reel
  carrusel
  post
  story
  video
}

enum BriefStatus {
  idea
  en_desarrollo
  revision_interna
  aprobacion_cliente
  aprobado
  en_produccion
  en_edicion
  entregado
  cancelado
}

enum BriefRole {
  guionista
  productor
  editor
  copy
}

enum RecurrenceFreq {
  semanal
  quincenal
  mensual
}

enum ContentPieceStatus {
  listo
  programado
  publicado
  en_revision
  en_edicion
  pausado
  cancelado
}

enum CopyStatus {
  pendiente
  en_revision
  aprobado
}

model ContentBrief {
  id                  String          @id @default(cuid())
  clientId            String
  client              Client          @relation(fields: [clientId], references: [id])
  projectId           String?         @map("project_id")
  project             Project?        @relation("BriefProject", fields: [projectId], references: [id], onDelete: SetNull)
  title               String
  type                ContentType
  platforms           String[]
  status              BriefStatus     @default(idea)
  concept             String?
  script              String?
  referencesUrls      String[]
  copyDraft           String?
  hashtags            String?
  technicalNotes      String?
  clientApprovalNotes String?
  isRecurring         Boolean         @default(false)
  recurrenceFreq      RecurrenceFreq?
  createdById         String
  createdBy           User            @relation("BriefCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  assignees           BriefAssignee[]
  history             BriefHistory[]
  contentPieces       ContentPiece[]
  clientApprovals     ClientContentApproval[]
  files               BriefFile[]
  comments            BriefComment[]
  productionTasks     Task[]          @relation("BriefTasks")
  scripts             Script[]        @relation("BriefScripts")

  @@index([clientId, status])
  @@index([status])
  @@map("content_briefs")
}

model BriefComment {
  id           String    @id @default(cuid())
  briefId      String    @map("brief_id")
  brief        ContentBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  authorId     String    @map("author_id")
  author       User      @relation("BriefCommentAuthor", fields: [authorId], references: [id])
  parentId     String?   @map("parent_id")
  parent       BriefComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      BriefComment[] @relation("CommentReplies")
  content      String
  isResolved   Boolean   @default(false) @map("is_resolved")
  resolvedById String?   @map("resolved_by_id")
  resolvedBy   User?     @relation("BriefCommentResolver", fields: [resolvedById], references: [id])
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  mentions     CommentMention[]

  @@index([briefId, parentId, createdAt])
  @@map("brief_comments")
}

model CommentMention {
  id        String   @id @default(cuid())
  commentId String   @map("comment_id")
  comment   BriefComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation("CommentMentionUser", fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@map("comment_mentions")
}

model BriefFile {
  id           String      @id @default(cuid())
  briefId      String
  brief        ContentBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  uploadedById String
  uploader     User        @relation("BriefFileUploader", fields: [uploadedById], references: [id])
  originalName String
  storedName   String
  filePath     String
  mimeType     String
  sizeBytes    Int
  label        String?     // optional display label
  createdAt    DateTime    @default(now())

  @@index([briefId])
  @@map("brief_files")
}

model BriefAssignee {
  id           String       @id @default(cuid())
  briefId      String
  brief        ContentBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation("BriefAssigneeUser", fields: [userId], references: [id])
  role         BriefRole
  assignedById String
  assignedBy   User         @relation("BriefAssignedBy", fields: [assignedById], references: [id])
  assignedAt   DateTime     @default(now())

  @@unique([briefId, userId, role])
  @@index([briefId, userId])
  @@map("brief_assignees")
}

model BriefHistory {
  id          String       @id @default(cuid())
  briefId     String
  brief       ContentBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User         @relation("BriefHistoryActor", fields: [actorId], references: [id])
  eventType   String
  description String
  meta        Json?
  createdAt   DateTime     @default(now())

  @@index([briefId, createdAt(sort: Desc)])
  @@map("brief_history")
}

model ContentPiece {
  id               String             @id @default(cuid())
  briefId          String?
  brief            ContentBrief?      @relation(fields: [briefId], references: [id])
  clientId         String
  client           Client             @relation(fields: [clientId], references: [id])
  title            String
  type             ContentType
  platforms        String[]
  status           ContentPieceStatus @default(listo)
  copy             String?
  hashtags         String?
  referencesUrls   String[]
  copyStatus       CopyStatus         @default(pendiente)
  publicationNotes String?
  scheduledDate    DateTime?          @db.Date
  scheduledTime    String?
  publishedAt      DateTime?
  createdById      String
  createdBy        User               @relation("PieceCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  history          ContentPieceHistory[]
  clientApprovals  ClientContentApproval[]

  @@index([scheduledDate, status])
  @@index([clientId, status])
  @@index([briefId])
  @@map("content_pieces")
}

model ContentPieceHistory {
  id          String       @id @default(cuid())
  pieceId     String
  piece       ContentPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User         @relation("PieceHistoryActor", fields: [actorId], references: [id])
  eventType   String
  description String
  meta        Json?
  createdAt   DateTime     @default(now())

  @@index([pieceId, createdAt(sort: Desc)])
  @@map("content_piece_history")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedById String?

  @@map("system_settings")
}

// ── Client Portal ─────────────────────────────────────────────────────────────

model ClientPortalToken {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  token     String   @unique
  month     String   // '2025-06'
  expiresAt DateTime
  createdAt DateTime @default(now())

  approvals ClientContentApproval[]

  @@unique([clientId, month])
  @@index([token])
  @@map("client_portal_tokens")
}

model ClientMonthlyObjective {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  month          String   // '2025-06'
  engagementGoal String?
  reachGoal      String?
  followersGoal  String?
  leadsGoal      String?
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clientId, month])
  @@index([clientId, month])
  @@map("client_monthly_objectives")
}

// ── Docs ─────────────────────────────────────────────────────────────────────

model DocPage {
  id            String    @id @default(cuid())
  title         String    @default("Sin título")
  icon          String?
  cover         String?
  parentId      String?
  parent        DocPage?  @relation("DocPageChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children      DocPage[] @relation("DocPageChildren")
  contextType   String
  contextId     String
  content       Json      @default("[]")
  isPublished   Boolean   @default(true)
  sortOrder     Int       @default(0)
  // New fields added via raw SQL (snake_case in DB)
  pageStatus    String    @default("borrador") @map("page_status")
  isTemplate    Boolean   @default(false)      @map("is_template")
  templateName  String?                        @map("template_name")
  templateDesc  String?                        @map("template_desc")
  approvedById  String?                        @map("approved_by_id")
  approvedAt    DateTime?                      @map("approved_at")
  createdById   String
  createdBy     User      @relation("DocPageCreator",  fields: [createdById],  references: [id])
  updatedById   String?
  updatedBy     User?     @relation("DocPageUpdater",  fields: [updatedById],  references: [id])
  approvedBy    User?     @relation("DocPageApprover", fields: [approvedById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  versions      DocPageVersion[]
  favoritedBy   DocFavorite[]

  @@index([contextType, contextId, parentId])
  @@index([parentId, sortOrder])
  @@map("doc_pages")
}

model DocPageVersion {
  id        String   @id @default(cuid())
  pageId    String   @map("page_id")
  page      DocPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  version   Int
  content   Json
  savedById String   @map("saved_by_id")
  savedBy   User     @relation("DocVersionSaver", fields: [savedById], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([pageId, version])
  @@index([pageId, createdAt(sort: Desc)])
  @@map("doc_page_versions")
}

model DocFavorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation("DocFavoriteUser", fields: [userId], references: [id], onDelete: Cascade)
  pageId    String   @map("page_id")
  page      DocPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, pageId])
  @@map("doc_favorites")
}

model ClientContentApproval {
  id         String   @id @default(cuid())
  pieceId    String?
  piece      ContentPiece?    @relation(fields: [pieceId], references: [id])
  briefId    String?
  brief      ContentBrief?    @relation(fields: [briefId], references: [id])
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  tokenId    String
  token      ClientPortalToken @relation(fields: [tokenId], references: [id])
  action     String   // 'approved' | 'changes_requested'
  changeType String?  // 'copy' | 'design' | 'date' | 'concept' | 'other'
  feedback   String?
  actionedAt DateTime @default(now())

  @@index([pieceId])
  @@index([briefId])
  @@index([clientId, actionedAt(sort: Desc)])
  @@map("client_content_approvals")
}

model DriveConnection {
  id            String    @id @default(cuid())
  accessToken   String    @map("access_token") @db.Text
  refreshToken  String    @map("refresh_token") @db.Text
  expiryDate    BigInt    @map("expiry_date")
  connectedById String    @map("connected_by_id")
  connectedBy   User      @relation(fields: [connectedById], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("drive_connections")
}

// ── Scripts (Guiones) ─────────────────────────────────────────────────────────

enum ScriptStatus {
  borrador
  en_revision
  aprobado
  archivado
}

model Script {
  id          String        @id @default(cuid())
  briefId     String        @map("brief_id")
  brief       ContentBrief  @relation("BriefScripts", fields: [briefId], references: [id], onDelete: Cascade)
  clientId    String        @map("client_id")
  client      Client        @relation("ClientScripts", fields: [clientId], references: [id])
  title       String
  type        ContentType
  status      ScriptStatus  @default(borrador)
  content     Json          @default("[]")
  notes       String?
  createdById String        @map("created_by_id")
  createdBy   User          @relation("ScriptCreator", fields: [createdById], references: [id])
  updatedById String?       @map("updated_by_id")
  updatedBy   User?         @relation("ScriptUpdater", fields: [updatedById], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  versions    ScriptVersion[]
  comments    ScriptComment[]

  @@index([briefId])
  @@index([clientId, status])
  @@map("scripts")
}

model ScriptVersion {
  id        String   @id @default(cuid())
  scriptId  String   @map("script_id")
  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  version   Int
  title     String
  content   Json
  notes     String?
  savedById String   @map("saved_by_id")
  savedBy   User     @relation("ScriptVersionSaver", fields: [savedById], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([scriptId, version])
  @@index([scriptId, createdAt(sort: Desc)])
  @@map("script_versions")
}

model ScriptComment {
  id         String          @id @default(cuid())
  scriptId   String          @map("script_id")
  script     Script          @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  authorId   String          @map("author_id")
  author     User            @relation("ScriptCommentAuthor", fields: [authorId], references: [id])
  parentId   String?         @map("parent_id")
  parent     ScriptComment?  @relation("ScriptCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    ScriptComment[] @relation("ScriptCommentReplies")
  content    String
  sceneIndex Int?            @map("scene_index")
  isResolved Boolean         @default(false) @map("is_resolved")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  mentions   ScriptCommentMention[]

  @@index([scriptId, parentId])
  @@map("script_comments")
}

model ScriptCommentMention {
  id        String        @id @default(cuid())
  commentId String        @map("comment_id")
  comment   ScriptComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String        @map("user_id")
  user      User          @relation("ScriptMentionUser", fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@map("script_comment_mentions")
}
